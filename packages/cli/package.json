{
  "name": "error-to-fix",
  "version": "1.1.1",
  "type": "module",
  "description": "Instant fixes for 3000+ error patterns across 50+ languages",
  "bin": {
    "error-to-fix": "./dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "keywords": ["error", "fix", "debug", "cli", "developer-tools", "diagnostics"],
  "author": "Satyam Thakur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Satyamtechy/error-to-fix.git"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('data',{recursive:true});fs.copyFileSync('../shared/error-database-full.json','data/errors.json')\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "13.1.0"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "typescript": "5.7.3"
  }
}
